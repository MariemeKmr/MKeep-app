# ----- Base de données -----
# Local (docker-compose) :
DATABASE_URL=mysql+pymysql://mkeep:mkeep@localhost:3306/mkeep
# Production (Aiven) : remplace par l'URI fournie par Aiven, ex :
# DATABASE_URL=mysql+pymysql://avnadmin:MOT_DE_PASSE@mysql-xxxx.aivencloud.com:12345/defaultdb?ssl_ca=ca.pem

# ----- Sécurité JWT -----
JWT_SECRET=change-moi-avec-une-cle-longue-et-aleatoire
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ----- CORS (origines autorisées, séparées par des virgules) -----
CORS_ORIGINS=http://localhost:3000,https://mkeep-app.vercel.app
